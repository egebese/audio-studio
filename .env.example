# FAL_KEY is required for uploads, generation, and health readiness.
FAL_KEY=your-fal-key

# install.sh generates a strong STUDIO_PASSWORD; replace this placeholder.
STUDIO_PASSWORD=changeme

# A generated 32-byte minimum STUDIO_SESSION_SECRET is required.
STUDIO_SESSION_SECRET=replace-me

# Optional direct OpenAI fallback for naming and prompt enhancement.
OPENAI_API_KEY=your-openai-api-key

# Optional model overrides.
AUDIO_STUDIO_NAME_MODEL=openai/gpt-4o-mini
AUDIO_STUDIO_PROMPT_MODEL=openai/gpt-4o
AUDIO_STUDIO_CINEMATIC_MODEL=anthropic/claude-sonnet-4.5

# Safe local bind and release image selection.
BIND_ADDRESS=127.0.0.1
PORT=3000
AUDIO_STUDIO_VERSION=latest
